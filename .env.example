# 複製本檔為 .env.local 後，將 NOTION_API_KEY、NOTION_DATABASE_ID 改成你的真實值。
# Integration：https://www.notion.so/my-integrations

NOTION_API_KEY=secret_xxxxxxxx
NOTION_DATABASE_ID=貼上你的_DB_ID

# --- 核心欄位（中文資料庫）---
NOTION_PROP_TITLE=標題
NOTION_PROP_STATUS=狀態
NOTION_PROP_CONTENT=內文
NOTION_PROP_SCHEDULED=排程時間
NOTION_PROP_PLATFORMS=發文平台

NOTION_STATUS_DRAFT=草稿
NOTION_STATUS_SCHEDULED=已排程
NOTION_STATUS_PUBLISHED=已發佈

# --- 選填：發佈／自動化／支柱 ---
NOTION_PROP_PUBLISHED_URL=發佈連結
NOTION_PROP_PILLAR=內容支柱
NOTION_PILLAR_OPTIONS=教學,開箱,促銷,幕後
NOTION_PROP_LAST_SYNC_ERROR=同步錯誤

# --- 選填：營運與財務（團隊建議）---
NOTION_PROP_CAMPAIGN=活動檔期
NOTION_CAMPAIGN_OPTIONS=春節檔,開學季,品牌月,常態
NOTION_PROP_ESTIMATED_TRAFFIC=預估導流
NOTION_PROP_ACTUAL_COST=實際花費
NOTION_PROP_BUSINESS_NOTE=商務備註

# --- 選填：回饋與專案 ---
NOTION_PROP_PERF_NOTE=成效備註
NOTION_PROP_AUDIENCE_VERBATIM=觀眾原話
NOTION_PROP_CLIENT_PROJECT=客戶專案

# --- 選填：n8n Webhook ---
# N8N_WEBHOOK_URL=https://你的-n8n/webhook/xxx
# N8N_WEBHOOK_SECRET=自訂密鑰（標頭 X-Webhook-Secret）

# --- 英文欄位資料庫時可改回 Title, Status, Content… ---
