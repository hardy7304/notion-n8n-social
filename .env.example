# 複製為 .env.local 並填入真實值
# https://www.notion.so/my-integrations

NOTION_API_KEY=secret_xxxxxxxx

# Notion 資料庫頁面 → Share → Copy link 中的 32 字元 ID（可含或不含連字號）
NOTION_DATABASE_ID=貼上你的_DB_ID

# 以下選填：若你的資料庫欄位名稱不同，請對應修改
# NOTION_PROP_TITLE=Title
# NOTION_PROP_STATUS=Status
# NOTION_PROP_CONTENT=Content
# NOTION_PROP_SCHEDULED=Scheduled
# NOTION_PROP_PLATFORMS=Platforms

# Status 選項名稱須與 Notion select 選項完全一致
# NOTION_STATUS_DRAFT=Draft
# NOTION_STATUS_SCHEDULED=Scheduled
# NOTION_STATUS_PUBLISHED=Published

# --- n8n Webhook（選填）：Notion 寫入成功後 POST  JSON 觸發工作流 ---
# N8N_WEBHOOK_URL=https://你的-n8n/webhook/xxx
# N8N_WEBHOOK_SECRET=自訂密鑰（會放在標頭 X-Webhook-Secret，n8n 可驗證）

# --- Notion 進階欄位（選填）：與 n8n 回寫／報表用 ---
# NOTION_PROP_PUBLISHED_URL=發佈連結
# NOTION_PROP_PILLAR=內容支柱
# NOTION_PILLAR_OPTIONS=教學,開箱,促銷,幕後
# NOTION_PROP_LAST_SYNC_ERROR=同步錯誤
